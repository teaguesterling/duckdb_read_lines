# name: test/sql/read_lines_line_endings.test
# description: Line-splitting semantics — trailing empty lines, terminator
# group: [sql]

#              preservation, lone CR, BOM, invalid UTF-8, tail-range context.
#              Regression tests for issue #5. Content is asserted EXACTLY
#              (terminators encoded as <CR>/<LF>), never rtrim'd, so these
#              tests cannot mask terminator bugs.

require read_lines

# =============================================================================
# Trailing empty line ("a\n\n" = 2 lines; "\n" alone = 1 line)
# Must agree with wc -l, grep -n '', and parse_lines.
# =============================================================================

query I
SELECT count(*) FROM read_lines('test/data/trailing_blank.txt');
----
2

query I
SELECT count(*) FROM read_lines('test/data/only_newline.txt');
----
1

# parse_lines agrees on the same bytes
query I
SELECT count(*) FROM parse_lines('a' || chr(10) || chr(10));
----
2

# =============================================================================
# Terminators are preserved in content (as the README documents)
# =============================================================================

query II
SELECT line_number, replace(replace(content, chr(13), '<CR>'), chr(10), '<LF>')
FROM read_lines('test/data/trailing_blank.txt') ORDER BY line_number;
----
1	a<LF>
2	<LF>

# CRLF endings: split correctly, both bytes preserved, true byte offsets
query III
SELECT line_number, replace(replace(content, chr(13), '<CR>'), chr(10), '<LF>'), byte_offset
FROM read_lines('test/data/crlf.txt') ORDER BY line_number;
----
1	one<CR><LF>	0
2	two<CR><LF>	5
3	three<CR><LF>	10

# A final line without a trailing terminator keeps its (lack of) terminator
query II
SELECT line_number, replace(replace(content, chr(13), '<CR>'), chr(10), '<LF>')
FROM read_lines('test/data/no_trailing_newline.txt', '+1') ORDER BY line_number;
----
3	third

# =============================================================================
# Lone CR (classic-Mac) is a line separator, preserved in content
# =============================================================================

query III
SELECT line_number, replace(replace(content, chr(13), '<CR>'), chr(10), '<LF>'), byte_offset
FROM read_lines('test/data/lone_cr.txt') ORDER BY line_number;
----
1	a<CR>	0
2	b<CR>	2
3	c	4

# parse_lines agrees on the same bytes
query I
SELECT count(*) FROM parse_lines('a' || chr(13) || 'b' || chr(13) || 'c');
----
3

# =============================================================================
# UTF-8 BOM is stripped from line 1; byte offsets stay true source offsets
# =============================================================================

query III
SELECT line_number, replace(content, chr(10), '<LF>'), byte_offset
FROM read_lines('test/data/bom.txt') ORDER BY line_number;
----
1	hello<LF>	3
2	world<LF>	9

# BOM'd first line compares equal to its logical content
query I
SELECT count(*) FROM read_lines('test/data/bom.txt')
WHERE content = 'hello' || chr(10);
----
1

# =============================================================================
# Invalid UTF-8: clear error by default, skippable with ignore_errors
# (line numbers stay true to the file when a line is skipped)
# =============================================================================

statement error
SELECT * FROM read_lines('test/data/invalid_utf8.txt');
----
is not valid UTF-8

query II
SELECT line_number, replace(content, chr(10), '<LF>')
FROM read_lines('test/data/invalid_utf8.txt', ignore_errors=true) ORDER BY line_number;
----
1	ok1<LF>
3	ok3<LF>

# =============================================================================
# Tail range plus after-context ('2- +5') must not overflow into 0 rows
# =============================================================================

query I
SELECT count(*) FROM read_lines('test/data/simple.txt', '2- +5');
----
4

query I
SELECT count(*) FROM read_lines('test/data/simple.txt', lines='3-', after=2);
----
3

# =============================================================================
# From-end references on files with non-LF endings resolve correctly
# =============================================================================

query II
SELECT line_number, replace(replace(content, chr(13), '<CR>'), chr(10), '<LF>')
FROM read_lines('test/data/crlf.txt', '+2');
----
2	two<CR><LF>

query II
SELECT line_number, replace(replace(content, chr(13), '<CR>'), chr(10), '<LF>')
FROM read_lines('test/data/lone_cr.txt', '+1');
----
3	c

# =============================================================================
# read_lines_lateral agrees with read_lines on every fixture
# =============================================================================

query II
SELECT l.line_number, replace(replace(l.content, chr(13), '<CR>'), chr(10), '<LF>')
FROM (VALUES ('test/data/trailing_blank.txt')) v(p), read_lines_lateral(v.p) l
ORDER BY l.line_number;
----
1	a<LF>
2	<LF>

query III
SELECT l.line_number, replace(replace(l.content, chr(13), '<CR>'), chr(10), '<LF>'), l.byte_offset
FROM (VALUES ('test/data/lone_cr.txt')) v(p), read_lines_lateral(v.p) l
ORDER BY l.line_number;
----
1	a<CR>	0
2	b<CR>	2
3	c	4

query III
SELECT l.line_number, replace(l.content, chr(10), '<LF>'), l.byte_offset
FROM (VALUES ('test/data/bom.txt')) v(p), read_lines_lateral(v.p) l
ORDER BY l.line_number;
----
1	hello<LF>	3
2	world<LF>	9

statement error
SELECT * FROM (VALUES ('test/data/invalid_utf8.txt')) v(p), read_lines_lateral(v.p) l;
----
is not valid UTF-8

# =============================================================================
# trim argument (optional third positional; also named for read_lines and
# parse_lines). A pure content transform: line numbers, byte offsets, and
# selection are unaffected. Default (NULL/false) preserves content exactly.
# fixture whitespace.txt: "  indented  \n" / "\tTabbed\t\r\n" / "plain\n"
# =============================================================================

# true = strip the terminator only (chomp)
query II
SELECT line_number, replace(replace(replace(replace(content, chr(13), '<CR>'), chr(10), '<LF>'), chr(9), '<TAB>'), ' ', '<SP>')
FROM read_lines('test/data/whitespace.txt', NULL, true) ORDER BY line_number;
----
1	<SP><SP>indented<SP><SP>
2	<TAB>Tabbed<TAB>
3	plain

# 'right' = terminator + trailing spaces/tabs
query II
SELECT line_number, replace(replace(replace(replace(content, chr(13), '<CR>'), chr(10), '<LF>'), chr(9), '<TAB>'), ' ', '<SP>')
FROM read_lines('test/data/whitespace.txt', NULL, 'right') ORDER BY line_number;
----
1	<SP><SP>indented
2	<TAB>Tabbed
3	plain

# 'left' = leading spaces/tabs only; terminator kept
query II
SELECT line_number, replace(replace(replace(replace(content, chr(13), '<CR>'), chr(10), '<LF>'), chr(9), '<TAB>'), ' ', '<SP>')
FROM read_lines('test/data/whitespace.txt', NULL, 'left') ORDER BY line_number;
----
1	indented<SP><SP><LF>
2	Tabbed<TAB><CR><LF>
3	plain<LF>

# 'both' = both sides (terminator gone)
query II
SELECT line_number, replace(replace(replace(replace(content, chr(13), '<CR>'), chr(10), '<LF>'), chr(9), '<TAB>'), ' ', '<SP>')
FROM read_lines('test/data/whitespace.txt', NULL, 'both') ORDER BY line_number;
----
1	indented
2	Tabbed
3	plain

# named form on read_lines
query II
SELECT line_number, replace(replace(content, chr(9), '<TAB>'), ' ', '<SP>')
FROM read_lines('test/data/whitespace.txt', trim=true) ORDER BY line_number;
----
1	<SP><SP>indented<SP><SP>
2	<TAB>Tabbed<TAB>
3	plain

# combined with a lines selection; byte_offset unaffected by trim
query III
SELECT line_number, replace(replace(content, chr(9), '<TAB>'), ' ', '<SP>'), byte_offset
FROM read_lines('test/data/whitespace.txt', '2', 'both');
----
2	Tabbed	13

# false and NULL preserve exactly (same as default)
query I
SELECT count(*) FROM read_lines('test/data/crlf.txt', NULL, false) WHERE content LIKE '%' || chr(10);
----
3

# parse_lines named trim
query II
SELECT line_number, replace(content, ' ', '<SP>')
FROM parse_lines('  a  ' || chr(10) || 'b' || chr(13), trim='both') ORDER BY line_number;
----
1	a
2	b

# lateral: positional trim with NULL lines placeholder
query II
SELECT l.line_number, replace(replace(l.content, chr(9), '<TAB>'), ' ', '<SP>')
FROM (VALUES ('test/data/whitespace.txt')) v(p), read_lines_lateral(v.p, NULL, 'both') l
ORDER BY l.line_number;
----
1	indented
2	Tabbed
3	plain

# lateral: bare boolean trim with a lines selection
query II
SELECT l.line_number, replace(replace(l.content, chr(9), '<TAB>'), ' ', '<SP>')
FROM (VALUES ('test/data/whitespace.txt')) v(p), read_lines_lateral(v.p, '1-2', true) l
ORDER BY l.line_number;
----
1	<SP><SP>indented<SP><SP>
2	<TAB>Tabbed<TAB>

# invalid mode is a clear bind error
statement error
SELECT * FROM read_lines('test/data/simple.txt', NULL, 'sideways');
----
Invalid trim mode
