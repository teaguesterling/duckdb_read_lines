# name: test/sql/read_lines_shellfs.test
# description: Test read_lines with non-seekable sources (shellfs pipes)
# group: [sql]

require read_lines

require shellfs

# =============================================================================
# read_lines with shellfs pipes (fallback byte tracking)
# =============================================================================

# Basic pipe read
query II
SELECT line_number, rtrim(content, chr(10) || chr(13))
FROM read_lines('printf "line1\nline2\nline3" |');
----
1	line1
2	line2
3	line3

# Pipe with line selection (forward-only, no from-end)
query II
SELECT line_number, rtrim(content, chr(10) || chr(13))
FROM read_lines('printf "a\nb\nc\nd\ne" |', '2-4');
----
2	b
3	c
4	d

# Single line selection from pipe
query II
SELECT line_number, rtrim(content, chr(10) || chr(13))
FROM read_lines('printf "first\nsecond\nthird" |', 2);
----
2	second

# Byte offsets use fallback computation for pipes
query III
SELECT line_number, rtrim(content, chr(10) || chr(13)), byte_offset
FROM read_lines('printf "aa\nbb\ncc" |');
----
1	aa	0
2	bb	3
3	cc	6

# =============================================================================
# read_lines_lateral with non-seekable source (should error)
# =============================================================================

statement error
SELECT l.*
FROM (VALUES ('printf "hello" |')) AS v(cmd),
     read_lines_lateral(v.cmd) AS l;
----
read_lines_lateral does not support non-seekable sources

# =============================================================================
# From-end selection on non-seekable source (should error)
# =============================================================================

statement error
SELECT * FROM read_lines('printf "a\nb\nc" |', '+2');
----
from-end line selection requires a seekable source

# =============================================================================
# Regression: seekable file sources still work exactly as before
# =============================================================================

# Normal file read
query II
SELECT line_number, rtrim(content, chr(10) || chr(13))
FROM read_lines('test/data/simple.txt');
----
1	line one
2	line two
3	line three
4	line four
5	line five

# File with line selection
query II
SELECT line_number, rtrim(content, chr(10) || chr(13))
FROM read_lines('test/data/simple.txt', '2-4');
----
2	line two
3	line three
4	line four

# File with from-end selection (seekable, should work)
query II
SELECT line_number, rtrim(content, chr(10) || chr(13))
FROM read_lines('test/data/simple.txt', '+2');
----
4	line four

# Lateral with normal file (seekable, should work)
query III
SELECT v.path, l.line_number, rtrim(l.content, chr(10) || chr(13))
FROM (VALUES ('test/data/single_line.txt')) AS v(path),
     read_lines_lateral(v.path) AS l;
----
test/data/single_line.txt	1	only one line

# Lateral with multiple seekable files
query II
SELECT v.path LIKE '%log1%' AS is_log1, count(*)
FROM (VALUES ('test/data/log1.txt'), ('test/data/log2.txt')) AS v(path),
     read_lines_lateral(v.path) AS l
GROUP BY v.path
ORDER BY v.path;
----
true	5
false	3
